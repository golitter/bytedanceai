# AgentEnd 环境变量示例
# 使用方法：cp agentend/.env.example agentend/.env，然后填入实际值
#
# 其余配置（server / workspace / database / agents 等）走 agentend/config.yaml
# 此处只放 LLM 密钥与 LangSmith 追踪密钥（避免硬编码到 YAML）

# ─── DeepSeek LLM（Orchestrator 必填） ───
# 从 https://platform.deepseek.com 获取 API Key
DS_MODEL=deepseek-chat
DS_BASE_URL=https://api.deepseek.com
DS_API_KEY=sk-CHANGE_ME

# ─── LangSmith 追踪（可选） ───
# 启用 LangSmith 追踪，记录 Agent 的决策过程和工具调用，便于后续分析和优化
# 两个都要配置才能启用追踪功能；不需要追踪可注释或留空
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_CHANGE_ME
LANGSMITH_PROJECT=agenthub
