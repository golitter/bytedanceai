{
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "npx eslint --fix --max-warnings=0 --config frontend/eslint.config.js",
      "prettier --write"
    ],
    "backend/**/*.go": [
      "gofmt -w",
      "goimports -w"
    ],
    "agentend/**/*.py": [
      "ruff check --fix --config agentend/ruff.toml",
      "ruff format --config agentend/ruff.toml"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
