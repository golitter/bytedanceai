@startuml
title AgentHub Runtime 持久化数据模型

' =====================================================
' Layout
' =====================================================

left to right direction
hide methods
hide circle

skinparam dpi 180
skinparam shadowing false
skinparam linetype ortho
skinparam roundcorner 10
skinparam nodesep 54
skinparam ranksep 56

' =====================================================
' Global Dark Console Style
' =====================================================

skinparam backgroundColor #0A0B0E
skinparam defaultFontName "JetBrains Mono"
skinparam defaultFontSize 12
skinparam defaultFontColor #E5E7EB

skinparam ArrowColor #8B949E
skinparam ArrowThickness 1.2

skinparam title {
  FontColor #F9FAFB
  FontSize 20
  FontStyle bold
  BackgroundColor #0A0B0E
  BorderColor #0A0B0E
}

skinparam package {
  BackgroundColor #0F1117
  BorderColor #2B2F3A
  FontColor #C9D1D9
  FontSize 13
  FontStyle bold
}

skinparam class {
  BackgroundColor #151922
  BorderColor #3A3F4B
  FontColor #F9FAFB
  FontSize 12
  AttributeFontColor #D1D5DB
  AttributeFontSize 11
  AttributeIconSize 0
}

skinparam classHeaderBackgroundColor #1A1D24

skinparam note {
  BackgroundColor #111827
  BorderColor #374151
  FontColor #D1D5DB
  FontSize 11
}

' =====================================================
' Stereotype Color Overrides
' =====================================================

skinparam class<<core>> {
  BackgroundColor #151922
  BorderColor #6366F1
  FontColor #F9FAFB
  AttributeFontColor #DDE3EA
}

skinparam class<<collab>> {
  BackgroundColor #151922
  BorderColor #64748B
  FontColor #F9FAFB
  AttributeFontColor #DDE3EA
}

skinparam class<<skill>> {
  BackgroundColor #151922
  BorderColor #8B5CF6
  FontColor #F9FAFB
  AttributeFontColor #DDE3EA
}

skinparam class<<admin>> {
  BackgroundColor #151922
  BorderColor #4B5563
  FontColor #F9FAFB
  AttributeFontColor #DDE3EA
}

' =====================================================
' Legend
' =====================================================

legend right
  <color:#F9FAFB><b>标记说明</b></color>
  <color:#D1D5DB>PK  主键</color>
  <color:#D1D5DB>UK  唯一键</color>
  <color:#D1D5DB>IDX 普通索引</color>
  --
  <color:#818CF8>紫色</color> 核心 Runtime 链路
  <color:#A78BFA>紫粉</color> Skill 绑定关系
  <color:#CBD5E1>灰色</color> 辅助业务关系
  <color:#CBD5E1>虚线</color> 逻辑关联，非真实外键
endlegend

' =====================================================
' Core Runtime
' =====================================================

package "CORE RUNTIME / 核心运行数据" as core {
  class "tasks\n任务主表" as tasks <<core>> {
    + id : bigint unsigned <<PK>>
    --
    + task_id : varchar(36) <<UK>>
    title : varchar(255)
    repo_path : varchar(512)
    status : varchar(32)
    pinned_at : datetime(3)
    created_at : datetime(3)
    updated_at : datetime(3)
  }

  class "sessions\nAgent 会话" as sessions <<core>> {
    + id : bigint unsigned <<PK>>
    --
    + session_id : varchar(128) <<UK>>
    task_id : varchar(36) <<IDX>>
    agent_type : varchar(64)
    agent_name : varchar(128)
    avatar_url : varchar(512)
    status : varchar(32)
    settled_diff : longtext
    diff_status : varchar(32)
    soul_md : varchar(300)
    created_at : datetime(3)
    updated_at : datetime(3)
  }

  class "messages\n消息流记录" as messages <<core>> {
    + id : bigint unsigned <<PK>>
    --
    + message_id : varchar(36) <<UK>>
    task_id : varchar(36) <<IDX>>
    session_id : varchar(191) <<IDX>>
    role : varchar(16)
    content : longtext
    status : varchar(16)
    last_seq : varchar(64)
    agent_type : varchar(64)
    agent_name : varchar(128)
    created_at : datetime(3)
    group_id : varchar(64) <<IDX>>
  }

  class "session_agents\n会话 Agent 元信息" as session_agents <<core>> {
    + id : bigint unsigned <<PK>>
    --
    + session_id : varchar(128) <<UK>>
    agent_type : varchar(64)
    agent_name : varchar(128)
    avatar_url : varchar(512)
    created_at : datetime(3)
    updated_at : datetime(3)
  }

  class "diff_snapshots\nDiff 快照" as diff_snapshots <<core>> {
    + id : bigint unsigned <<PK>>
    --
    + snapshot_id : varchar(36) <<UK>>
    session_id : varchar(128) <<IDX>>
    diff_content : longtext
    status : varchar(16)
    created_at : datetime(3)
    updated_at : datetime(3)
  }
}

' =====================================================
' Collaboration
' =====================================================

package "COLLABORATION / 协作与分组" as collab {
  class "announcements\n任务公告" as announcements <<collab>> {
    + id : bigint unsigned <<PK>>
    --
    task_id : varchar(36) <<IDX>>
    sender_id : varchar(64)
    sender_name : varchar(64)
    content : text
    pinned : tinyint(1)
    created_at : datetime(3)
  }

  class "contact_groups\n任务分组" as contact_groups <<collab>> {
    + id : bigint unsigned <<PK>>
    --
    + group_id : varchar(36) <<UK>>
    name : varchar(128)
    sort_order : bigint
    created_at : datetime(3)
    updated_at : datetime(3)
  }

  class "contact_group_items\n分组任务项" as contact_group_items <<collab>> {
    + id : bigint unsigned <<PK>>
    --
    group_id : varchar(36) <<IDX>>
    task_id : varchar(36) <<IDX>>
    sort_order : bigint
    created_at : datetime(3)
  }
}

' =====================================================
' Skill System
' =====================================================

package "SKILL SYSTEM / 技能系统" as skill {
  class "skill_hubs\n技能仓库" as skill_hubs <<skill>> {
    + id : bigint unsigned <<PK>>
    --
    + name : varchar(128) <<UK>>
    builtin : tinyint(1)
    storage_path : varchar(512)
    description : text
    file_count : bigint
    total_size : bigint
    uploaded_by : varchar(64)
    created_at : datetime(3)
    updated_at : datetime(3)
    content : longblob
  }

  class "agent_skill\n会话技能绑定" as agent_skill <<skill>> {
    + id : bigint unsigned <<PK>>
    --
    session_id : varchar(128)
    skill_name : varchar(128)
    agent_type : varchar(32)
    imported_at : datetime(3)
  }
}

' =====================================================
' Admin Config
' =====================================================

package "ADMIN CONFIG / 管理配置" as admin {
  class "admin_settings\n系统配置" as admin_settings <<admin>> {
    + key : varchar(64) <<PK>>
    --
    value : varchar(1024)
  }
}

' =====================================================
' Logical Relationships
' 原始 SQL 没有显式 FOREIGN KEY，以下是逻辑关系
' =====================================================

tasks ||-[#818CF8]-o{ sessions : "task_id"
tasks ||-[#818CF8]-o{ messages : "task_id"
sessions ||-[#818CF8]-o{ messages : "session_id"

sessions ||-[#6366F1]-|| session_agents : "session_id"
sessions ||-[#6366F1]-o{ diff_snapshots : "session_id"

sessions ||-[#A78BFA]-o{ agent_skill : "session_id"
skill_hubs ||-[#A78BFA,dashed]-o{ agent_skill : "name / skill_name"

tasks ||-[#CBD5E1]-o{ announcements : "task_id"
tasks ||-[#CBD5E1]-o{ contact_group_items : "task_id"
contact_groups ||-[#CBD5E1]-o{ contact_group_items : "group_id"

note bottom of tasks
  task_id 是业务唯一标识
  id 是数据库内部自增主键
end note

note bottom of skill_hubs
  skill_hubs.name 与 agent_skill.skill_name
  当前是逻辑关联，不是数据库外键
end note
@enduml